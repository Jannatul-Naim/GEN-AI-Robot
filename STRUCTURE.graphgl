gen_ai_robot/
├── README.md
├── requirements.txt
│
├── vision/                         # Perception (russparry)
│   ├── __init__.py
│   ├── vision.py                   # YOLO + VisionThread (your code)
│   └── vision_server.py            # /vision Flask API
│
├── brain/                          # Cognition (PC)
│   ├── __init__.py
│   ├── brain.py                    # LLM + planner (your code)
│   ├── vision_client.py            # HTTP client for /vision
│   └── run_brain.py                # Main loop (user → brain)
│
├── robit_serialization/                  # Actuation bridge (russparry)
│   ├── __init__.py
│   ├── robot_server.py             # /robot Flask API (your code)
│   ├── serializer.py               # JSON → motion packets (future)
│   ├── ik_solver.py                # IK (future)
│   └── esp32_bridge.py             # UART/WiFi/MQTT (future)
│
├── speech/                         # Audio I/O (future)
│   ├── __init__.py
│   ├── stt.py                      # Speech-to-text
│   └── tts.py                      # Text-to-speech
│
├── launch/                         # Entry points
│   ├── run_vision_stack.py         # Vision + /vision server
│   ├── run_robot_stack.py          # /robot serialization server
│   └── run_all_russparry.py        # Vision + robot server
│
└── utils/
    ├── __init__.py
    └── timing.py
